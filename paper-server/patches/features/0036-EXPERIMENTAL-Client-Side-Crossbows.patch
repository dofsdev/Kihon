         if (!level.isClientSide()) {
             CrossbowItem.ChargingSounds chargingSounds = this.getChargingSounds(stack);
-            float f = (float)(stack.getUseDuration(livingEntity) - count) / getChargeDuration(stack, livingEntity);
+
