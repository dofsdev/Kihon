+    //EXPERIMENTAL PING HELPER
+    private static int getPingCompTicks(LivingEntity entity) {
+        if (entity instanceof ServerPlayer sp) {
+            // latency is round-trip ms in most server impls.
+            // Use half RTT as an estimate of one-way delay.
+            int rttMs = sp.connection.latency();
+            int oneWayMs = rttMs / 2;
+
+            // convert ms to ticks (50ms per tick)
+            return Mth.ceil(oneWayMs / 50.0F);
+        }
+        return 0;
+    }
