     @Override
     public InteractionResult use(Level level, Player player, InteractionHand hand) {
-        ItemStack itemInHand = player.getItemInHand(hand);
-        ChargedProjectiles chargedProjectiles = itemInHand.get(DataComponents.CHARGED_PROJECTILES);
-        if (chargedProjectiles != null && !chargedProjectiles.isEmpty()) {
-            this.performShooting(level, player, hand, itemInHand, getShootingPower(chargedProjectiles), 1.0F, null);
+        ItemStack stack = player.getItemInHand(hand);
+        ChargedProjectiles charged = stack.get(DataComponents.CHARGED_PROJECTILES);
+
+        // If already charged, shoot immediately (vanilla behavior)
+        if (charged != null && !charged.isEmpty()) {
+            this.performShooting(level, player, hand, stack, getShootingPower(charged), 1.0F, null);
             return InteractionResult.CONSUME;
-        } else if (!player.getProjectile(itemInHand).isEmpty()) {
+        }
+
+        // If player has ammo, start using AND instantly charge on the server
+        if (!player.getProjectile(stack).isEmpty()) {
             this.startSoundPlayed = false;
             this.midLoadSoundPlayed = false;
+
+            // Start using so the client keeps its animation
             player.startUsingItem(hand);
+
+            // Server-side: charge immediately (removes ping/hold-time effect)
+            if (!level.isClientSide && !isCharged(stack)) {
+                // Paper: keep the event exactly like onUseTick does
+                final io.papermc.paper.event.entity.EntityLoadCrossbowEvent event =
+                    new io.papermc.paper.event.entity.EntityLoadCrossbowEvent(
+                        player.getBukkitLivingEntity(),
+                        stack.asBukkitMirror(),
+                        org.bukkit.craftbukkit.CraftEquipmentSlot.getHand(hand)
+                    );
+
+                if (event.callEvent()) {
+                    // IMPORTANT: pass event.shouldConsumeItem() so plugins can control consumption
+                    tryLoadProjectiles(player, stack, event.shouldConsumeItem());
+                }
+            }
+
             return InteractionResult.CONSUME;
-        } else {
-            return InteractionResult.FAIL;
         }
+
+        return InteractionResult.FAIL;
     }
 
+
     private static float getShootingPower(ChargedProjectiles projectile) {
         return projectile.contains(Items.FIREWORK_ROCKET) ? 1.6F : 3.15F;
     }
 
